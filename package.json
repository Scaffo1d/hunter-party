{
  "name": "hunter-party",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "concurrently -n web,server -c blue,green \"npm run dev --workspace=web\" \"npm run dev --workspace=server\"",
    "dev:web": "npm run dev --workspace=web",
    "dev:server": "npm run dev --workspace=server",
    "build": "npm run build --workspace=server && npm run build --workspace=web",
    "build:web": "npm run build --workspace=web",
    "build:server": "npm run build --workspace=server",
    "start:server": "npm run start --workspace=server",
    "test": "npm run test --workspace=@hunter-party/game-engine",
    "generate:board-import": "python3 scripts/generate-board-import.py",
    "copy-assets": "python3 scripts/copy-assets.py",
    "generate:game-data": "python3 scripts/generate-game-data.py",
    "smoke-test": "node scripts/smoke-test.mjs",
    "predeploy-check": "node scripts/predeploy-check.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "socket.io-client": "^4.8.1"
  }
}
